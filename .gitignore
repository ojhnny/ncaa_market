# ---- Data (reproducible from source; tracked via manifests, not committed) ----
data/raw/*
data/staging/*
data/marts/*
# keep the folders + their manifests/readmes in git
!data/raw/.gitkeep
!data/staging/.gitkeep
!data/marts/.gitkeep
!data/**/MANIFEST.md
!data/**/README.md
# The built analytics database (regenerated by the pipeline)
*.duckdb
*.sqlite
*.db

# ---- Secrets / config ----
.env
.env.*
config/secrets.yaml

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ---- Notebooks: keep source, ignore bulky outputs cache ----
notebooks/.ipynb_checkpoints/

# ---- Office / BI temp files ----
~$*.xlsx
~$*.docx
*.tmp

# ---- OS / editor ----
.DS_Store
Thumbs.db
.vscode/
.idea/
